{
  "info": {
    "name": "Hospital PMS API",
    "description": "All endpoints for the Hospital Patient Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:5001/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@hospital.com\", \"password\": \"admin123\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base}}/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/patients?page=1&limit=10", "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}, {"key": "search", "value": ""}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "url": "{{base}}/patients/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Patient Appointments",
          "request": {
            "method": "GET",
            "url": "{{base}}/patients/:id/appointments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "url": "{{base}}/patients",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Patient\",\n  \"gender\": \"Male\",\n  \"dob\": \"1992-06-15\",\n  \"phone\": \"9123456789\",\n  \"email\": \"test@example.com\",\n  \"bloodGroup\": \"A+\",\n  \"address\": \"123 Test Street, City\"\n}"
            }
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "url": "{{base}}/patients/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"phone\": \"9123456789\"\n}"
            }
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "url": "{{base}}/patients/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/doctors?search=", "query": [{"key": "search", "value": ""}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Doctor by ID",
          "request": {
            "method": "GET",
            "url": "{{base}}/doctors/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "url": "{{base}}/doctors",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Test Doctor\",\n  \"department\": \"Cardiology\",\n  \"qualification\": \"MBBS, MD\",\n  \"experience\": 5,\n  \"consultationFee\": 600,\n  \"mobile\": \"9000011111\"\n}"
            }
          }
        },
        {
          "name": "Update Doctor",
          "request": {
            "method": "PUT",
            "url": "{{base}}/doctors/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consultationFee\": 750\n}"
            }
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "url": "{{base}}/doctors/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "List Appointments",
          "request": {
            "method": "GET",
            "url": "{{base}}/appointments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Book Appointment",
          "request": {
            "method": "POST",
            "url": "{{base}}/appointments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": \"<patient_id>\",\n  \"doctor\": \"<doctor_id>\",\n  \"appointmentDate\": \"2026-07-20\",\n  \"appointmentTime\": \"10:00\",\n  \"reason\": \"General check-up\"\n}"
            }
          }
        },
        {
          "name": "Update Appointment",
          "request": {
            "method": "PUT",
            "url": "{{base}}/appointments/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentTime\": \"11:30\",\n  \"reason\": \"Follow-up consultation\"\n}"
            }
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "DELETE",
            "url": "{{base}}/appointments/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Global Search",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base}}/search?q=rohan", "query": [{"key": "q", "value": "rohan"}] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
